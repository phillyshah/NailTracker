# Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Direct connection for migrations (port 5432, bypasses PgBouncer pooler)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

JWT_SECRET=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me
PORT=3045
NODE_ENV=development
