datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

model User {
  id            String       @id @default(cuid())
  username      String       @unique
  password      String
  role          String       @default("admin")
  // Set for role = "distributor": scopes the account to one distributor's stock.
  distributorId String?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  createdAt     DateTime     @default(now())

  @@index([distributorId])
}

model Distributor {
  id        String          @id @default(cuid())
  name      String          @unique
  region    String?
  contact   String?
  email     String?
  phone     String?
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     InventoryItem[]
  banks     Bank[]
  users     User[]
}

model InventoryItem {
  id            String              @id @default(cuid())
  udi           String
  gtin          String
  gtinShort     String
  lot           String
  expDate       DateTime?
  rawBarcode    String
  productLabel  String?
  imageData     String?
  distributorId String?
  distributor   Distributor?        @relation(fields: [distributorId], references: [id])
  assignedAt    DateTime?
  assignedBy    String?
  bankId        String?
  bank          Bank?               @relation(fields: [bankId], references: [id])
  usedAt        DateTime?
  usageTicketId String?
  deletedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  history       AssignmentHistory[]

  @@index([udi])
  @@index([distributorId])
  @@index([expDate])
  @@index([deletedAt])
  @@index([gtinShort])
  @@index([usedAt])
  @@index([bankId])
  @@index([usageTicketId])
}

model AssignmentHistory {
  id                  String        @id @default(cuid())
  itemId              String
  item                InventoryItem @relation(fields: [itemId], references: [id])
  fromDistributorId   String?
  fromDistributorName String?
  toDistributorId     String?
  toDistributorName   String?
  changedAt           DateTime      @default(now())
  changedBy           String?
  note                String?

  @@index([itemId])
}

model Transfer {
  id                  String         @id @default(cuid())
  transferId          String         @unique
  fromDistributorId   String?
  fromDistributorName String
  toDistributorId     String?
  toDistributorName   String
  note                String?
  itemCount           Int
  items               Json
  transferredBy       String?
  createdAt           DateTime       @default(now())

  @@index([transferId])
  @@index([createdAt])
}

model UsageTicket {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  distributorId   String?
  distributorName String
  note            String?
  itemCount       Int
  items           Json
  recordedBy      String?
  createdAt       DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@index([distributorId])
}

model Bank {
  id            String          @id @default(cuid())
  name          String          @unique
  description   String?
  distributorId String?
  distributor   Distributor?    @relation(fields: [distributorId], references: [id])
  createdBy     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         InventoryItem[]

  @@index([distributorId])
}

model ParLevel {
  id            String   @id @default(cuid())
  scope         String   @default("item") // "item" (SKU) or "category" (group)
  itemNumber    String? // set when scope = "item"
  category      String? // group name; set when scope = "category" (and on item rows for reference)
  gtinShort     String?
  distributorId String? // null = global default; otherwise a per-distributor override (item scope only)
  minStock      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([itemNumber])
  @@index([scope])
  @@index([category])
}

model AuditSession {
  id              String   @id @default(cuid())
  auditId         String   @unique
  distributorId   String?
  distributorName String
  matchedCount    Int
  missingCount    Int
  extraCount      Int
  items           Json
  note            String?
  createdBy       String?
  createdAt       DateTime @default(now())

  @@index([auditId])
  @@index([createdAt])
}

// OCR Training (TrackerLabs, admin-only). A labelled-correction dataset: admins
// upload label photos, the OCR matcher's guess is stored alongside the raw text,
// and they confirm/correct it. Confirmed corrections seed OcrAlias rows that the
// client matcher loads at boot — accuracy improves as the set grows.
model OcrTrainingSample {
  id            String   @id @default(cuid())
  imageData     String // compressed base64 data URL of the label photo
  rawText       String // raw Tesseract output
  parsedJson    Json // matcher's guess: [{ ref, gtin, lot, exp, gs1 }]
  correctedJson Json? // admin's corrected version (same shape)
  status        String   @default("pending") // pending | confirmed | corrected | rejected
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// A confirmed mis-read → canonical REF mapping. The matcher consults these to
// resolve tokens it would otherwise miss.
model OcrAlias {
  id           String   @id @default(cuid())
  token        String   @unique // the mis-read REF token as OCR produced it
  canonicalRef String // the catalog REF it should resolve to
  source       String   @default("training") // training | manual
  createdAt    DateTime @default(now())

  @@index([token])
}
