datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Distributor {
  id        String          @id @default(cuid())
  name      String          @unique
  region    String?
  contact   String?
  email     String?
  phone     String?
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     InventoryItem[]
  banks     Bank[]
}

model InventoryItem {
  id            String              @id @default(cuid())
  udi           String
  gtin          String
  gtinShort     String
  lot           String
  expDate       DateTime?
  rawBarcode    String
  productLabel  String?
  imageData     String?
  distributorId String?
  distributor   Distributor?        @relation(fields: [distributorId], references: [id])
  assignedAt    DateTime?
  assignedBy    String?
  bankId        String?
  bank          Bank?               @relation(fields: [bankId], references: [id])
  usedAt        DateTime?
  usageTicketId String?
  deletedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  history       AssignmentHistory[]

  @@index([udi])
  @@index([distributorId])
  @@index([expDate])
  @@index([deletedAt])
  @@index([gtinShort])
  @@index([usedAt])
  @@index([bankId])
  @@index([usageTicketId])
}

model AssignmentHistory {
  id                  String        @id @default(cuid())
  itemId              String
  item                InventoryItem @relation(fields: [itemId], references: [id])
  fromDistributorId   String?
  fromDistributorName String?
  toDistributorId     String?
  toDistributorName   String?
  changedAt           DateTime      @default(now())
  changedBy           String?
  note                String?

  @@index([itemId])
}

model Transfer {
  id                  String         @id @default(cuid())
  transferId          String         @unique
  fromDistributorId   String?
  fromDistributorName String
  toDistributorId     String?
  toDistributorName   String
  note                String?
  itemCount           Int
  items               Json
  transferredBy       String?
  createdAt           DateTime       @default(now())

  @@index([transferId])
  @@index([createdAt])
}

model UsageTicket {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  distributorId   String?
  distributorName String
  note            String?
  itemCount       Int
  items           Json
  recordedBy      String?
  createdAt       DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@index([distributorId])
}

model Bank {
  id            String          @id @default(cuid())
  name          String          @unique
  description   String?
  distributorId String?
  distributor   Distributor?    @relation(fields: [distributorId], references: [id])
  createdBy     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         InventoryItem[]

  @@index([distributorId])
}

model ParLevel {
  id            String   @id @default(cuid())
  scope         String   @default("item") // "item" (SKU) or "category" (group)
  itemNumber    String? // set when scope = "item"
  category      String? // group name; set when scope = "category" (and on item rows for reference)
  gtinShort     String?
  distributorId String? // null = global default; otherwise a per-distributor override (item scope only)
  minStock      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([itemNumber])
  @@index([scope])
  @@index([category])
}

model AuditSession {
  id              String   @id @default(cuid())
  auditId         String   @unique
  distributorId   String?
  distributorName String
  matchedCount    Int
  missingCount    Int
  extraCount      Int
  items           Json
  note            String?
  createdBy       String?
  createdAt       DateTime @default(now())

  @@index([auditId])
  @@index([createdAt])
}
